{
  "model_profile": "inherit",
  "commit_docs": true,
  "parallelization": true,
  "search_gitignored": true,
  "brave_search": false,
  "firecrawl": false,
  "exa_search": true,
  "git": {
    "branching_strategy": "none",
    "phase_branch_template": "gsd/phase-{phase}-{slug}",
    "milestone_branch_template": "gsd/{milestone}-{slug}",
    "quick_branch_template": null
  },
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist_validation": true,
    "auto_advance": false,
    "node_repair": true,
    "node_repair_budget": 2,
    "ui_phase": true,
    "ui_safety_gate": true,
    "text_mode": true,
    "research_before_questions": true,
    "discuss_mode": "discuss",
    "skip_discuss": false,
    "code_review": true,
    "code_review_depth": "standard"
  },
  "hooks": {
    "context_warnings": true
  },
  "project_code": null,
  "phase_naming": "sequential",
  "agent_skills": {
    "gsd-researcher": [
      ".claude/skills/agent-reach/SKILL.md",
      ".claude/skills/agent-reach/references/search.md"
    ]
  },
  "mode": "interactive",
  "granularity": "fine"
}
